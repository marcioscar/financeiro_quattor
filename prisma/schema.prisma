generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "mongodb"
    url      = env("DATABASE_URL")
}

model receitas {
    id                  String    @id @default(auto()) @map("_id") @db.ObjectId
    forma               String?
    descricao           String?
    valor               Float?
    data                DateTime?
    status              String?
    /// Hash (data+descricao+valor) das receitas importadas do extrato bancário —
    /// usado para descartar lançamentos já importados quando o arquivo semanal
    /// se sobrepõe a semanas anteriores. Ausente em receitas criadas manualmente.
    /// Sem `@unique`: no MongoDB isso quebraria a criação manual de receitas
    /// (índice único trata "campo ausente" como null e não aceita duas ausências).
    origem_extrato_hash String?

    @@index([origem_extrato_hash])
}

model despesas {
    id          String    @id @default(auto()) @map("_id") @db.ObjectId
    conta       String?
    descricao   String?
    valor       Float?
    data        DateTime?
    pago        Boolean?
    tipo        String?
    boleto_path String?
    recibo_path String?

    @@map("despesas")
}

type FolhaSalarios {
    data   DateTime? @db.Date
    decimo Float?
    ferias Float?
    fgts   Float?
    pago   Boolean?
    sal_id String?
    valor  Float?
}

model folha {
    id         String          @id @default(auto()) @map("_id") @db.ObjectId
    conta      String
    funcao     String
    modalidade String
    nome       String
    salarios   FolhaSalarios[]
}

model contas {
    id       String  @id @default(auto()) @map("_id") @db.ObjectId
    etiqueta String
    conta    String
    tipo     String?
}

model cancelamentos {
    id               String    @id @default(auto()) @map("_id") @db.ObjectId
    aluno            String?
    contato          String?
    plano            String?
    motivo           String?
    data_solicitacao DateTime?
    data_conclusao   DateTime?
    conclusao        String?
    valor_estornar   String?
    stone            String?
    data_limite      DateTime?
    cancelado        Boolean?  @default(false)
    recibo           String?
}

type Exercicio {
    nome       String?
    Repeticoes String?
    obs        String?
    video      String?
    carga      String?
}

type ExercicioBancoTreino {
    exercicio  String?
    observacao String?
    video      String?
    repeticoes String?
}

model treinos {
    id         String      @id @default(auto()) @map("_id") @db.ObjectId
    grupo      String
    semana     Int
    exercicios Exercicio[]
}

model banco_treino {
    id         String                 @id @default(auto()) @map("_id") @db.ObjectId
    ciclo      String?
    treino     String?
    grupo      String?
    exercicios ExercicioBancoTreino[]

    @@map("banco_treinos")
}

model ponto {
    id        String   @id @default(auto()) @map("_id") @db.ObjectId
    nome      String
    matricula Int
    entrada   DateTime
    saida     DateTime
}

type ItemContrato {
    id_cliente     Int?
    id_plano       Int?
    nome_cliente   String?
    nome_plano     String?
    valor_total    Float?
    mensalidade    Float?
    repasse        Float?
    data_inicio    String?
    data_fim       String?
    nome_professor String?
    id_professor   Int?
}

model contratos {
    id               String         @id @default(auto()) @map("_id") @db.ObjectId
    mes              Int
    ano              Int
    plano_filtro     String
    plano_label      String?
    professor_filtro String
    nome_professor   String?
    total_alunos     Int
    total_repasse    Float
    gravado_em       DateTime       @default(now())
    itens            ItemContrato[]

    @@unique([mes, ano, plano_filtro, professor_filtro], name: "contrato_mes_plano_professor")
    @@index([mes, ano])
    @@map("contratos")
}

type ItemNotaFiscal {
    id_evo            String
    tipo              String?
    numero            String?
    status            String?
    data_emissao      DateTime?
    enviada_por_email Boolean?
    nome_cliente      String?
    valor_total       Float?
    link_download_pdf String?
}

/**
 * Cache mensal de notas fiscais (EVO/eNotas). Meses fechados (anteriores ao
 * mês corrente) são gravados uma vez e nunca mais consultados na EVO. O mês
 * corrente é sincronizado de forma incremental via `ultima_sincronizacao_em`.
 */
model notas_fiscais_mes {
    id                      String           @id @default(auto()) @map("_id") @db.ObjectId
    mes                     Int
    ano                     Int
    fechado                 Boolean          @default(false)
    ultima_sincronizacao_em DateTime?
    gravado_em              DateTime         @default(now())
    itens                   ItemNotaFiscal[]

    @@unique([mes, ano], name: "notas_fiscais_mes_ano")
}

/**
 * Vendas importadas do extrato CSV da Stone (operadora de cartão). O CSV
 * baixado sempre traz o mês inteiro, então a importação é idempotente por
 * `stone_id` (único por transação) — reimportar o mesmo arquivo (ou um mais
 * recente que sobreponha dias já importados) não duplica nada.
 */
model vendas_stone {
    id            String    @id @default(auto()) @map("_id") @db.ObjectId
    stone_id      String    @unique
    documento     String?
    data_venda    DateTime
    bandeira      String?
    produto       String?
    n_parcelas    Int?
    valor_bruto   Float
    valor_liquido Float?
    ultimo_status String?
    importado_em  DateTime  @default(now())

    @@index([data_venda])
}
